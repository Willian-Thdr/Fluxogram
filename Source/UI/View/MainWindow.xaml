<Window x:Class="Fluxogram.Source.Application.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fluxogram"
        mc:Ignorable="d"
        Title="MainWindow" 
        Height="720" 
        Width="1080">
    <Grid x:Name="canvasRoot" Background="White">
        <Grid>
            <Grid.Background>
                <SolidColorBrush Color="#FFFFFF"/>
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0">
                <StackPanel>
                    <StackPanel.Background>
                        <SolidColorBrush Color="#40B3B3B3"/>
                    </StackPanel.Background>

                    <Label Content="Menu" Width="60" Height="32" Margin="0, 15, 150, 0" 
                        FontSize="20" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        
                    <Button x:Name="MenuButton" Content="≡" Margin="0, -26, 10, 0" Width="26" Height="26"
                            FontSize="15" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="SaveButton" Content="Salvar" Margin="0, 20, 0, 0" Width="125" 
                        Height="30" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Top"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" Opacity="0.25"/>

            <Border Grid.Column="2" CornerRadius="30">
                <TabControl Background="#20FFFFFF" BorderBrush="Transparent" BorderThickness="0" x:Name="Abas">
                    <TabItem Header="Menu" Width="55" Height="24" FontSize="14" 
                        Background="#207c7c7c" BorderBrush="Black"
                        BorderThickness="0" Margin="5, 0, 0, 0" x:Name="NaoEditavel">

                        <Canvas x:Name="MainWindowId" MouseMove="AreaMove">
                            <Canvas.Background>
                                <LinearGradientBrush StartPoint="0, 0" EndPoint="1, 1">
                                    <GradientStop Color="#708AEF" Offset="0"/>
                                    <GradientStop Color="#5B1094" Offset="1"/>
                                </LinearGradientBrush>
                            </Canvas.Background>
                                
                            <Grid Canvas.Left="0" Canvas.Right="0" Width="857" Height="50">
                                <Label Content="Início" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                            </Grid>

                            <Ellipse x:Name="MouseGlow"
                                     Width="40"
                                     Height="40"
                                     IsHitTestVisible="false">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#20FFFFFF"
                                                      Offset="0"/>
                                        <GradientStop Color="#01FFFFFF"
                                                      Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>

                            <Button x:Name="CreateFlux" Content="Criar novo fluxograma"
                                Background="Transparent" BorderBrush="Black" BorderThickness="1" 
                                Padding="10" Width="160" Height="40" Canvas.Left="25" Canvas.Top="100"
                                HorizontalAlignment="Left" VerticalAlignment="Top">
                                
                                <Button.Template>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding  BorderBrush}"
                                                BorderThickness="{TemplateBinding  BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>

                            </Button>
        
                            <Button x:Name="LoadFlux" Content="Carregar Fluxograma" Background="Transparent" 
                                BorderBrush="Black" BorderThickness="1" Padding="10" Width="150" Height="40" 
                                Canvas.Left="25" Canvas.Top="150" HorizontalAlignment="Left" VerticalAlignment="Top">

                                <Button.Template>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Border Background="{TemplateBinding  Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Canvas>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
