<Window x:Class="Fluxogram.Source.Application.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fluxogram"
        mc:Ignorable="d"
        Title="MainWindow" 
        Height="720" 
        Width="1080">
    <Grid x:Name="canvasRoot" Background="White">
    
        <Grid>
            <Grid.Background>
                <SolidColorBrush Color="#FFFFFF"/>
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0">
                <StackPanel>
                    <StackPanel.Background>
                        <SolidColorBrush Color="#40B3B3B3"/>
                    </StackPanel.Background>

                    <Grid Width="220" Height="50" Margin="0, 0, 0, 0">
                        <Label Content="Menu" Width="60" Height="32" 
                               Margin="10, 0, 0, 0" FontSize="20" HorizontalAlignment="Left"/>
                            
                        <Button x:Name="MenuButton" Content="≡" Margin="0, 6, 10, 0" Width="26" Height="26"
                                FontSize="15" HorizontalAlignment="Right" Background="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" Opacity="0.25"/>

            <Border Grid.Column="2" CornerRadius="30">
                <TabControl Background="#20FFFFFF" BorderBrush="Transparent" BorderThickness="0" x:Name="Abas">
                    <TabItem Header="Menu" Width="50" Height="24" FontSize="14" 
                        Background="#FFFFFF" BorderBrush="Black" Opacity="0.5"
                        BorderThickness="0" Margin="5, 0, 0, 0" HorizontalAlignment="Center" x:Name="NaoEditavel">
                        <Grid>
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0, 0" EndPoint="1, 1">
                                    <GradientStop Color="#708AEF" Offset="0"/>
                                    <GradientStop Color="#5B1094" Offset="1"/>
                                </LinearGradientBrush>
                            </Grid.Background>

                            <Label Content="Início" HorizontalAlignment="Center"
                                    VerticalAlignment="Top"/>

                            <Button x:Name="CreateFlux" Content="Criar novo fluxograma" Background="Transparent" BorderBrush="Black" 
                                    BorderThickness="1" Padding="10" Width="160" Height="40" Margin="-645, -510, 0, 0">
                                <Button.Template>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding  BorderBrush}"
                                                BorderThickness="{TemplateBinding  BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
        
                            <Button x:Name="LoadFlux" Content="Carregar Fluxograma" Background="Transparent" BorderBrush="Black" 
                                    BorderThickness="1" Padding="10" Width="150" Height="40" Margin="-640, -380, 0, 0">
                                <Button.Template>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Border Background="{TemplateBinding  Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
