<Window x:Class="Fluxogram.Source.Application.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fluxogram"
        mc:Ignorable="d"
        Title="MainWindow" 
        Height="720" 
        Width="1080">
    <Grid x:Name="canvasRoot" Background="White">
    
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#5B1094" Offset="0"/>
                    <GradientStop Color="#708AEF" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0">
                <StackPanel>
                    <StackPanel.Background>
                        <SolidColorBrush Color="#40B3B3B3"/>
                    </StackPanel.Background>

                    <Button x:Name="CreateFlux" Content="Criar novo fluxograma" Background="Transparent" 
                            BorderThickness="0" Margin="20, 50, 20, 0" Padding="10">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding  BorderBrush}"
                                        BorderThickness="{TemplateBinding  BorderThickness}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="LoadFlux" Content="Carregar Fluxograma" Background="Transparent" 
                            BorderThickness="0" Margin="20, 20, 20, 0" Padding="10">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border Background="{TemplateBinding  Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" Opacity="0.25"/>

            <Border Grid.Column="2" CornerRadius="30">
                <TabControl Background="#20FFFFFF" BorderBrush="Transparent" BorderThickness="0" x:Name="Abas">
                    <TabItem Header="Menu" Width="50" Height="24" FontSize="14" 
                        Background="#FFFFFF" BorderBrush="Black" Opacity="0.5"
                        BorderThickness="1" Margin="5, 0, 0, 0" HorizontalAlignment="Center" x:Name="NaoEditavel">
                        <Grid>
                            <Label Content="Início" 
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
